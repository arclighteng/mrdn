# Required — matches docker-compose.yml defaults
DATABASE_URL=postgresql://mrdn:mrdn@localhost:5432/mrdn?sslmode=disable

# Optional
MRDN_PORT=8080
MRDN_LOG_LEVEL=info

# External API keys — required when running `mrdn ingest`
# Note: MRDN_FINNHUB_API_KEY removed — Finnhub live stream no longer used
# MRDN_POLYGON_API_KEY=your_polygon_api_key
# MRDN_FEC_API_KEY=your_fec_api_key

# SSE connection limits (defaults shown)
# MRDN_SSE_MAX_PER_IP=3
# MRDN_SSE_MAX_PER_KEY=10
# MRDN_SSE_MAX_GLOBAL=500
